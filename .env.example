# ==========================================
# AgroNexus AI - Environment Variables
# ==========================================

# 1. Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Rotación automática de llaves para evitar límite 429
GEMINI_API_KEYS="key1,key2,key3"

# 2. Supabase Configuration (Database & Vector Store)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 3. Security & JWT (Supabase Auth Middleware for FastAPI)
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings
SUPABASE_JWK={"keys": []} # Optional: For ES256 verification if needed

# 4. API & Application Limits (Optional overrides)
MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.3
